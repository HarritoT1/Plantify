@code {
    [Parameter]
    public string table { get; set; } = ""; 

    [Parameter]
    public string? idquery { get; set; } = null; 

    private List<Dictionary<string, object>>? registrosQuery = new List<Dictionary<string, object>>();

    public string nameQuery { get; set; } = "Registros de toda la tabla USUARIOS";

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            if (!string.IsNullOrEmpty(idquery) && int.TryParse(idquery, out int idParsed))
            {
                registrosQuery = await queryService.GetQuery(idParsed);
            }
            else
            {
                switch (table)
                {
                    case "users":
                        registrosQuery = await queryService.GetQuery(0);
                        break;
                    case "clientes":
                        registrosQuery = await queryService.GetQuery(1);
                        break;
                    case "pedidos":
                        registrosQuery = await queryService.GetQuery(2);
                        break;
                    case "detalles":
                        registrosQuery = await queryService.GetQuery(3);
                        break;
                    case "productos":
                        registrosQuery = await queryService.GetQuery(4);
                        break;
                    case "gamas":
                        registrosQuery = await queryService.GetQuery(5);
                        break;
                    default:
                        Console.WriteLine($"Tabla desconocida: {table}");
                        break;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al ejecutar query: {ex.Message}");
            errorMessage = $"Error cargando los datos: {ex.Message}";
        }
    }

    private void asigNameQuery(string name) {
        nameQuery = name;
    }

    private string? errorMessage;

    private async Task Salir()
    {
        // Redirigir a la página principal u otra que prefieras...
        NavigationManager.NavigateTo("/");
    }

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;
}