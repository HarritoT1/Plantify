                <h2 class="text-primary fw-bold fs-4 text-center text-lg-start">Resultados de la consulta seleccionada de DB (@nameQuery):</h2>
                <div class="table-responsive small rounded" style="max-height: 800px; overflow: auto;">
                    <table class="table table-md table-bordered table-dark" style= "border-spacing: 6px;">
                        <thead class="table-dark bg-success">
                            <tr>
                                @if (registrosQuery?.Any() == true)
                                {
                                    foreach (var key in registrosQuery[0].Keys.ToList())
                                    {
                                        <th class="fs-4 fw-bold text-success text-center" style="text-transform: uppercase; vertical-align: middle;">@key</th>
                                    }
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (registrosQuery != null)
                            {
                                foreach (var row in registrosQuery)
                                {
                                    <tr>
                                        @foreach (var val in row.Values)
                                        {
                                            <td class="text-center" style="vertical-align: middle;">
                                                @{
                                                    var strVal = val?.ToString();
                                                    if (string.IsNullOrEmpty(strVal))
                                                    {
                                                        strVal = "null";
                                                    }
                                                }

                                                @if (strVal != "null" && strVal.EndsWith(".png", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <img src="img/producto/@strVal" alt="imagen" style="max-height: auto; max-width: 100%; border-radius: 15px;" />
                                                }
                                                else
                                                {
                                                    @strVal
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
