@code {

    string mensajeError = string.Empty;

    List<PedidoDTO> ListPedidosUser = new List<PedidoDTO>();

    protected override async Task OnParametersSetAsync()
    {
        ListPedidosUser = await listarPedidosUser.Lista(Convert.ToString(clienteGlobal.Cliente?.Id ?? 1));
    }

    private async Task Salir()
    {
        // Limpiar cliente global o datos de sesión temporales...
        clienteGlobal.Cliente = null;
        // También puedes limpiar otros datos como:
        pedidoDTOGlobal = new PedidoDTO(); // si quieres reiniciar todo...

        // Redirigir a la página principal u otra que prefieras
        NavigationManager.NavigateTo("/");
    }

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    public async Task ocultarPedido(string namePedido)
    {
        var result = await listarPedidosUser.UpdateVisibility(namePedido);

        if (!result)
        {
            mensajeError = "Lo siento algo salio mal con la eliminación de tu pedido.";
        }

        else {
            NavigationManager.NavigateTo("/List_Pedidos", forceLoad: true); // ← fuerza recarga.
        }
    }
}