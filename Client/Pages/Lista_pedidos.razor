<!-- PRIMERA SECCIÓN PEDIDOS PENDIENTES. -->

<div class="container main-space-div">
    <div class="d-flex align-items-center p-3 my-3 bg-dark-cont mg-3 rounded">
        <img class="me-sm-3 me-2 buttonAnimation" src="img/LOGOTIPO01.png" alt="" width="48" height="38">
        <div class="lh-1">
            <h1 class="mb-0 lh-1 fs-4 fs-sm-3 text-center">Listado de tus pedidos en Plantify.com</h1>
        </div>
    </div>

    <div class="my-3 p-3 bg-body rounded shadow-sm pb-4">
        <h6 class="border-bottom pb-2 mb-0">Pedidos en proceso:</h6>
        <div style="overflow: auto; max-height: 500px;">
            @foreach (var pedido in ListPedidosUser)
            {
                if (pedido.Estado == "Pendiente")
                {
                    <div class="d-flex text-body-secondary border-bottom pt-3 pb-2 align-items-center">
                        <img src="img/Envio_proceso.png" alt="Pedido en proceso"
                        class="flex-shrink-0 me-3 rounded bg-icono-amarillo buttonAnimation" width="50" height="50">
                        <div class="flex-grow-1 text-ped-con" style="overflow-x: auto; overflow-y: hidden;">
                            <strong class="d-block text-gray-dark">@pedido.NombrePedido</strong>
                            <span class="small"> Consulta los detalles de tu pedido realizado el @pedido.FechaPedido?.ToString("dd/MM/yyyy") <a
                                href="/PedidoRead/@(Uri.EscapeDataString(pedido.NombrePedido!))" class="buttonAnimation aqui">aquí</a>.</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- SENGUNDA SECCIÓN PEDIDOS CONCLUIDOS. -->

    <div class="my-3 p-3 bg-body rounded shadow-sm pb-4">
        <h6 class="border-bottom pb-2 mb-0">Pedidos concluidos:</h6>
        <div style="overflow: auto; max-height: 500px;">
        @foreach (var pedido in ListPedidosUser)
        {
            if (pedido.Estado == "Entregado" && pedido.HiddenClient != true)
            {
                    <div class="d-flex text-body-secondary border-bottom pt-3 pb-2 align-items-center" style="padding-right: 15px;">
                        <img src="img/PedidoEntregado.png" alt="Pedido concluido"
                        class="flex-shrink-0 me-3 rounded bg-icono-verde buttonAnimation" width="50" height="50">
                        <div class="flex-grow-1 text-ped-con" style="overflow-x: auto; overflow-y: hidden;">
                            <strong class="d-block text-gray-dark">@pedido.NombrePedido</strong>
                            <span class="small">Consulta los detalles de tu pedido realizado el @pedido.FechaPedido?.ToString("dd/MM/yyyy") <a
                                href="/PedidoRead/@(Uri.EscapeDataString(pedido.NombrePedido!))" class="buttonAnimation aqui">aquí</a>.</span>
                        </div>
                        <button class="btn btn-sm btn-borrar buttonAnimation p-1" title="Eliminar pedido" @onclick="@(() => ocultarPedido(pedido.NombrePedido ?? ""))">
                            <img src="img/basura.png" alt="borrar" width="25" height="25">
                        </button>
                    </div>
            }

            else if (pedido.Estado == "Rechazado"  && pedido.HiddenClient != true) {
                    <div class="d-flex text-body-secondary border-bottom pt-3 pb-2 align-items-center" style="padding-right: 15px;">
                        <img src="img/PedidoRechazado.png" alt="Pedido concluido"
                        class="flex-shrink-0 me-3 rounded bg-icono-rojo buttonAnimation" width="50" height="50">
                        <div class="flex-grow-1 text-ped-con" style="overflow-x: auto; overflow-y: hidden;">
                            <strong class="d-block text-gray-dark">@pedido.NombrePedido</strong>
                            <span class="small">Consulta los detalles de tu pedido realizado el @pedido.FechaPedido?.ToString("dd/MM/yyyy") <a
                                href="/PedidoRead/@(Uri.EscapeDataString(pedido.NombrePedido!))" class="buttonAnimation aqui">aquí</a>.</span>
                        </div>
                        <button class="btn btn-sm btn-borrar buttonAnimation p-1" title="Eliminar pedido" @onclick="@(() => ocultarPedido(pedido.NombrePedido ?? ""))">
                            <img src="img/basura.png" alt="borrar" width="25" height="25">
                        </button>
                    </div>
            }
        }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger my-3" role="alert">
            @mensajeError
        </div>
    }
</div>

